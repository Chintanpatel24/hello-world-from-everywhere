// Axum - Hello World
use axum::{Router, routing::get};
async fn hello() -> &'static str { "Hello, World!" }
#[tokio::main]
async fn main() {
    let app = Router::new().route("/", get(hello));
    axum::Server::bind(&"0.0.0.0:3000".parse().unwrap())
        .serve(app.into_make_service()).await.unwrap();
}